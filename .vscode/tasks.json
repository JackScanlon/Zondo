{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Debug",
			"type": "shell",
			"command": "zig",
			"args": [
				"build",
				"-Doptimize=Debug",
				"-freference-trace",
				"--prefix",
				"zig-out"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": ["$zig"]
		}
	]
}
