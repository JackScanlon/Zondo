#> Args
TRG_PG_VER=17.5
TRG_DEB_REL="trixie"

#> Postgres
PG_CFG="./docker/config/postgresql.conf"
PG_DBN="dbinst"
PG_SSL="disable"
PG_ARGS="--encoding=UTF-8 --lc-collate=C --lc-ctype=C"
PG_PORT=5432
PG_HOST="postgres"
PG_USER="postgres"
PG_PWD="somePgPassword123"
