# Editor configuration, see ref @ http://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
max_line_length = false
spelling_language = en-gb
insert_final_newline = true
trim_trailing_whitespace = true

[*.sql]
indent_size = 2
indent_style = space

[*.{zig,zon}]
rulers = 120
indent_size = 4
indent_style = space

[*.{json,jsonc}]
indent_size = 2
indent_style = tab

[*.{yml,yaml,toml}]
indent_size = 2
indent_style = space

[*.{md,mdx}]
indent_size = 4
indent_style = tab
trim_trailing_whitespace = false

[{Dockerfile,*.Dockerfile,Dockerfile.*,*.env,env.*,*.env.*,*.sh,*.conf}]
indent_size = 2
indent_style = space

[**/{migrations,bin,out,.output,build,.cache,logs}/**/*]
generated_code = true
